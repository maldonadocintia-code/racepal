rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPublicUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.isPublic == true;
    }

    function isFollowing(targetUid) {
      return exists(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + targetUid));
    }

    function canViewUser(uid) {
      return isOwner(uid) || isPublicUser(uid) || isFollowing(uid);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      // Owner can update any field. Other signed-in users may only adjust the
      // denormalised follower/following counts — needed because follow /
      // unfollow / accept-request batches touch both users' docs at once.
      allow update: if isOwner(uid) || (
        isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followersCount', 'followingCount'])
      );
      allow delete: if false;
    }

    // ── Races ─────────────────────────────────────────────────────────────────
    match /races/{raceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Creator can edit; anyone signed-in may update aggregate stats only
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['reviewCount', 'averageRating', 'recommendPercent', 'lightningBolt', 'attendeeCount']
        )
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ── Attendances ───────────────────────────────────────────────────────────
    match /attendances/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId ||
                      isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public reviews visible to all signed-in users
      // Followers-only reviews visible only to followers
      allow read: if isSignedIn() && (
        resource.data.isPublic == true ||
        isOwner(resource.data.userId) ||
        isFollowing(resource.data.userId)
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // ── Follows ───────────────────────────────────────────────────────────────
    match /follows/{docId} {
      allow read: if isSignedIn();
      // The follower creates a direct follow; the target creates the follow
      // when accepting a request (acceptRequest writes on their behalf).
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.followerUid ||
        request.auth.uid == request.resource.data.followingUid
      );
      // Either side can delete: the follower unfollows, or the target removes
      // a follower.
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.followerUid ||
        request.auth.uid == resource.data.followingUid
      );
    }

    // ── Follow requests ───────────────────────────────────────────────────────
    match /follow_requests/{docId} {
      // resource == null covers reads of a not-yet-existing request doc
      // (the common case when checking follow status) — without this the
      // rule errors on the null resource and denies the read.
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid == resource.data.requesterUid ||
        request.auth.uid == resource.data.targetUid
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.requesterUid;
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.requesterUid ||
        request.auth.uid == resource.data.targetUid
      );
    }

    // ── Activity feed ─────────────────────────────────────────────────────────
    match /activities/{actId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
