rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPublicUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.isPublic == true;
    }

    function isFollowing(targetUid) {
      return exists(/databases/$(database)/documents/follows/$(request.auth.uid + '_' + targetUid));
    }

    function canViewUser(uid) {
      return isOwner(uid) || isPublicUser(uid) || isFollowing(uid);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ── Races ─────────────────────────────────────────────────────────────────
    match /races/{raceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (resource.data.createdBy == request.auth.uid || resource.data.createdBy == 'system');
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ── Attendances ───────────────────────────────────────────────────────────
    match /attendances/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId ||
                      isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public reviews visible to all signed-in users
      // Followers-only reviews visible only to followers
      allow read: if isSignedIn() && (
        resource.data.isPublic == true ||
        isOwner(resource.data.userId) ||
        isFollowing(resource.data.userId)
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // ── Follows ───────────────────────────────────────────────────────────────
    match /follows/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.followerUid;
      allow delete: if isSignedIn() &&
        request.auth.uid == resource.data.followerUid;
    }

    // ── Follow requests ───────────────────────────────────────────────────────
    match /follow_requests/{docId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.requesterUid ||
        request.auth.uid == resource.data.targetUid
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.requesterUid;
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.requesterUid ||
        request.auth.uid == resource.data.targetUid
      );
    }

    // ── Activity feed ─────────────────────────────────────────────────────────
    match /activities/{actId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
