rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Pals are stored as two mirrored docs: pals/{owner}_{other}. We're pals with
    // `otherUid` if the doc owned by us pointing at them exists.
    function isPal(otherUid) {
      return exists(/databases/$(database)/documents/pals/$(request.auth.uid + '_' + otherUid));
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      // Only the owner edits their profile. The Pals model no longer keeps
      // denormalised follower counts on other users' docs, so no cross-user
      // writes are needed.
      allow update: if isOwner(uid);
      // Owner may delete their own profile (GDPR right to erasure / account
      // deletion). The app wipes the user's other data first, then this doc.
      allow delete: if isOwner(uid);
    }

    // ── Races ─────────────────────────────────────────────────────────────────
    match /races/{raceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Creator can edit; anyone signed-in may update aggregate stats only
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['reviewCount', 'averageRating', 'recommendPercent', 'lightningBolt', 'attendeeCount']
        )
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ── Attendances ───────────────────────────────────────────────────────────
    match /attendances/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId ||
                      isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Public reviews visible to all signed-in users;
      // pals-only reviews visible to the author and their pals.
      allow read: if isSignedIn() && (
        resource.data.isPublic == true ||
        isOwner(resource.data.userId) ||
        isPal(resource.data.userId)
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // ── Pals ──────────────────────────────────────────────────────────────────
    // Two mirrored docs per friendship: pals/{ownerUid}_{otherUid}. Created when
    // a request is accepted (the accepter writes both directions); either party
    // may delete (unfriend), which removes both docs.
    match /pals/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.ownerUid ||
        request.auth.uid == request.resource.data.otherUid
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.ownerUid ||
        request.auth.uid == resource.data.otherUid
      );
    }

    // ── Pal requests ────────────────────────────────────────────────────────────
    match /pal_requests/{docId} {
      // resource == null covers reads of a not-yet-existing request doc (status
      // checks) — without it the rule errors on the null resource and denies.
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.fromUid;
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
    }

    // ── Legacy follows (read-only, for the one-off migration to Pals) ───────────
    match /follows/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /follow_requests/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Activity feed ─────────────────────────────────────────────────────────
    match /activities/{actId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
